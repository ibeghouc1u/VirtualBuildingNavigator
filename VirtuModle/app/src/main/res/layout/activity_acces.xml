<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".AccesActivity">

    <!-- Barre d'outils -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="414dp"
        android:layout_height="64dp"
        android:background="#9146ff"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="@string/app_name" />

    <!-- 🎯 Affichage de la direction sélectionnée -->
    <TextView
        android:id="@+id/tvSelectedDirection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 📸 ImageView pour afficher la photo sélectionnée -->

    <!-- 🟥 Rectangle Rouge pour la sélection (Invisible au départ) -->
    <ImageView
        android:id="@+id/ivPhoto"
        android:layout_width="372dp"
        android:layout_height="432dp"
        android:adjustViewBounds="true"
        android:background="@android:color/darker_gray"
        android:contentDescription="@string/photo_preview"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toTopOf="@id/accessContainer"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/selectionRectangle"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="#80FF0000"
        android:visibility="gone"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/ivPhoto"
        app:layout_constraintStart_toStartOf="@id/ivPhoto"/>

    <!-- 📜 Section des accès ajoutés -->
    <LinearLayout
        android:id="@+id/accessContainer"
        android:layout_width="364dp"
        android:layout_height="154dp"
        android:layout_marginHorizontal="20dp"
        android:background="#442766"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnRetour"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvAccessTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/access_added"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Liste des accès ajoutés -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewAccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp" />
    </LinearLayout>

    <!-- 🔙 Boutons Retour et Terminer -->
    <Button
        android:id="@+id/btnRetour"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="@string/returnn"
        android:textColor="#FFFFFF"
        android:backgroundTint="#9146ff"
        android:textStyle="bold"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="30dp"/>

    <Button
        android:id="@+id/btnTerminer"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="@string/finish"
        android:textColor="#00FF00"
        android:backgroundTint="#9146ff"
        android:textStyle="bold"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp"
        android:layout_marginEnd="30dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
